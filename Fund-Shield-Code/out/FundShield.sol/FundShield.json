y\":\"nonpayable\",\"type\":\"function\"},{\"inputs\":[],\"name\":\"getAllTransactions\",\"outputs\":[{\"components\":[{\"internalType\":\"uint256\",\"name\":\"id\",\"type\":\"uint256\"},{\"internalType\":\"address\",\"name\":\"sender\",\"type\":\"address\"},{\"internalType\":\"address\",\"name\":\"receiver\",\"type\":\"address\"},{\"internalType\":\"uint256\",\"name\":\"amount\",\"type\":\"uint256\"},{\"internalType\":\"string\",\"name\":\"purpose\",\"type\":\"string\"},{\"internalType\":\"bool\",\"name\":\"flagged\",\"type\":\"bool\"},{\"internalType\":\"uint256\",\"name\":\"timestamp\",\"type\":\"uint256\"}],\"internalType\":\"struct FundShield.Transaction[]\",\"name\":\"\",\"type\":\"tuple[]\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[],\"name\":\"getFlaggedTransactions\",\"outputs\":[{\"components\":[{\"internalType\":\"uint256\",\"name\":\"id\",\"type\":\"uint256\"},{\"internalType\":\"address\",\"name\":\"sender\",\"type\":\"address\"},{\"internalType\":\"address\",\"name\":\"receiver\",\"type\":\"address\"},{\"internalType\":\"uint256\",\"name\":\"amount\",\"type\":\"uint256\"},{\"internalType\":\"string\",\"name\":\"purpose\",\"type\":\"string\"},{\"internalType\":\"bool\",\"name\":\"flagged\",\"type\":\"bool\"},{\"internalType\":\"uint256\",\"name\":\"timestamp\",\"type\":\"uint256\"}],\"internalType\":\"struct FundShield.Transaction[]\",\"name\":\"flagged\",\"type\":\"tuple[]\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"uint256\",\"name\":\"id\",\"type\":\"uint256\"}],\"name\":\"getTransaction\",\"outputs\":[{\"components\":[{\"internalType\":\"uint256\",\"name\":\"id\",\"type\":\"uint256\"},{\"internalType\":\"address\",\"name\":\"sender\",\"type\":\"address\"},{\"internalType\":\"address\",\"name\":\"receiver\",\"type\":\"address\"},{\"internalType\":\"uint256\",\"name\":\"amount\",\"type\":\"uint256\"},{\"internalType\":\"string\",\"name\":\"purpose\",\"type\":\"string\"},{\"internalType\":\"bool\",\"name\":\"flagged\",\"type\":\"bool\"},{\"internalType\":\"uint256\",\"name\":\"timestamp\",\"type\":\"uint256\"}],\"internalType\":\"struct FundShield.Transaction\",\"name\":\"\",\"type\":\"tuple\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[],\"name\":\"totalTransactions\",\"outputs\":[{\"internalType\":\"uint256\",\"name\":\"\",\"type\":\"uint256\"}],\"stateMutability\":\"view\",\"type\":\"function\"}],\"devdoc\":{\"details\":\"Minimal, demo-focused \\u2014 no access control, no upgradeability,      no external dependencies. Readability > gas optimisation.\",\"events\":{\"TransactionLogged(uint256,address,address,uint256,string,bool)\":{\"params\":{\"amount\":\"Value in wei.\",\"flagged\":\"Whether the record triggered a flag.\",\"id\":\"The new transaction's id.\",\"purpose\":\"Transfer description.\",\"receiver\":\"Intended fund destination.\",\"sender\":\"Who submitted the record.\"}}},\"kind\":\"dev\",\"methods\":{\"addTransaction(address,uint256,string)\":{\"details\":\"Zero-address receiver is intentionally ALLOWED here so the contract      can record burn-style transfers or donations to the zero address.      It is NOT flagged on its own; callers should use a non-empty purpose      string to document the intent. This keeps the contract minimal and      avoids encoding policy that differs by organisation.\",\"params\":{\"amount\":\"Transfer value in wei.\",\"purpose\":\"Human-readable description of the transfer.\",\"receiver\":\"Destination address (may be zero \\u2014 see dev note above).\"}},\"getAllTransactions()\":{\"details\":\"Returning a dynamic struct array is fine for a demo / dashboard         read; avoid calling this on-chain in production loops.\"},\"getFlaggedTransactions()\":{\"details\":\"Builds the result array in two passes to avoid dynamic memory         resizing. Gas cost is O(n); acceptable for a demo scenario.\"},\"getTransaction(uint256)\":{\"details\":\"Reverts with an array-index panic if `id >= totalTransactions()`.\"}},\"stateVariables\":{\"LARGE_AMOUNT_THRESHOLD\":{\"details\":\"1 000 ETH (in wei). Chosen because legitimate operational         transfers for a fund of typical hackathon / small-org size         are very unlikely to exceed this in a single transaction.         Adjust to your organisation's risk appetite before mainnet use.\"}},\"title\":\"FundShield\",\"version\":1},\"userdoc\":{\"events\":{\"TransactionLogged(uint256,address,address,uint256,string,bool)\":{\"notice\":\"Emitted every time a transaction is recorded.\"}},\"kind\":\"user\",\"methods\":{\"LARGE_AMOUNT_THRESHOLD()\":{\"notice\":\"Transactions whose `amount` exceeds this value are flagged.\"},\"addTransaction(address,uint256,string)\":{\"notice\":\"Record a new fund transaction and apply flagging rules. Flagging rules (any one suffices):   1. amount == 0            \\u2014 zero-value transfer is meaningless / suspicious.   2. purpose is empty       \\u2014 undocumented transfer is a transparency red flag.   3. amount > LARGE_AMOUNT_THRESHOLD \\u2014 unusually large single transfer.\"},\"getAllTransactions()\":{\"notice\":\"Returns every recorded transaction in insertion order.\"},\"getFlaggedTransactions()\":{\"notice\":\"Returns only transactions where `flagged == true`.\"},\"getTransaction(uint256)\":{\"notice\":\"Returns the transaction with the given `id`.\"},\"totalTransactions()\":{\"notice\":\"Returns the total number of recorded transactions.\"}},\"notice\":\"On-chain fund transparency system.         Every transaction is stored permanently and automatically         flagged when it matches any suspicious-activity rule.\",\"version\":1}},\"settings\":{\"compilationTarget\":{\"src/FundShield.sol\":\"FundShield\"},\"evmVersion\":\"prague\",\"libraries\":{},\"metadata\":{\"bytecodeHash\":\"ipfs\"},\"optimizer\":{\"enabled\":false,\"runs\":200},\"remappings\":[\":forge-std/=lib/forge-std/src/\"]},\"sources\":{\"src/FundShield.sol\":{\"keccak256\":\"0xf502d8a0f044b439436a2915