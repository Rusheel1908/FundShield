,"name":"getFlaggedTransactions","outputs":[{"internalType":"struct FundShield.Transaction[]","name":"flagged","type":"tuple[]","components":[{"internalType":"uint256","name":"id","type":"uint256"},{"internalType":"address","name":"sender","type":"address"},{"internalType":"address","name":"receiver","type":"address"},{"internalType":"uint256","name":"amount","type":"uint256"},{"internalType":"string","name":"purpose","type":"string"},{"internalType":"bool","name":"flagged","type":"bool"},{"internalType":"uint256","name":"timestamp","type":"uint256"}]}]},{"inputs":[{"internalType":"uint256","name":"id","type":"uint256"}],"stateMutability":"view","type":"function","name":"getTransaction","outputs":[{"internalType":"struct FundShield.Transaction","name":"","type":"tuple","components":[{"internalType":"uint256","name":"id","type":"uint256"},{"internalType":"address","name":"sender","type":"address"},{"internalType":"address","name":"receiver","type":"address"},{"internalType":"uint256","name":"amount","type":"uint256"},{"internalType":"string","name":"purpose","type":"string"},{"internalType":"bool","name":"flagged","type":"bool"},{"internalType":"uint256","name":"timestamp","type":"uint256"}]}]},{"inputs":[],"stateMutability":"view","type":"function","name":"totalTransactions","outputs":[{"internalType":"uint256","name":"","type":"uint256"}]}],"devdoc":{"kind":"dev","methods":{"addTransaction(address,uint256,string)":{"details":"Zero-address receiver is intentionally ALLOWED here so the contract      can record burn-style transfers or donations to the zero address.      It is NOT flagged on its own; callers should use a non-empty purpose      string to document the intent. This keeps the contract minimal and      avoids encoding policy that differs by organisation.","params":{"amount":"Transfer value in wei.","purpose":"Human-readable description of the transfer.","receiver":"Destination address (may be zero — see dev note above)."}},"getAllTransactions()":{"details":"Returning a dynamic struct array is fine for a demo / dashboard         read; avoid calling this on-chain in production loops."},"getFlaggedTransactions()":{"details":"Builds the result array in two passes to avoid dynamic memory         resizing. Gas cost is O(n); acceptable for a demo scenario."},"getTransaction(uint256)":{"details":"Reverts with an array-index panic if `id >= totalTransactions()`."}},"version":1},"userdoc":{"kind":"user","methods":{"LARGE_AMOUNT_THRESHOLD()":{"notice":"Transactions whose `amount` exceeds this value are flagged."},"addTransaction(address,uint256,string)":{"notice":"Record a new fund transaction and apply flagging rules. Flagging rules (any one suffices):   1. amount == 0            — zero-value transfer is meaningless / suspicious.   2. purpose is empty       — undocumented transfer is a transparency red flag.   3. amount > LARGE_AMOUNT_THRESHOLD — unusually large single transfer."},"getAllTransactions()":{"notice":"Returns every recorded transaction in insertion order."},"getFlaggedTransactions()":{"notice":"Returns only transactions where `flagged == true`."},"getTransaction(uint256)":{"notice":"Returns the transaction with the given `id`."},"totalTransactions()":{"notice":"Returns the total number of recorded transactions."}},"version":1}},"settings":{"remappings":["forge-std/=lib/forge-std/src/"],"optimizer":{"enabled":false,"runs":200},"metadata":{"bytecodeHash":"ipfs"},"compilationTarget":{"src/FundShield.sol":"FundShield"},"evmVersion":"prague","libraries":{}},"sources":{"src/FundShield.sol":{"keccak256":"0xf502d8a0f044b439436a2915ead811642af75db9b3def11596c2e909bc0500cf","urls":["bzz-raw://3983c72ff36fcd7b4562f1fc595296b61fa0ead05f3c777f50b188ee67b9af03","dweb:/ipfs/QmQxDvEg6Mmqecp5hCvYTrHsW7QeLZUL7RzCPcV3rycNdq"],"license":"MIT"}},"version":1},"id":21}